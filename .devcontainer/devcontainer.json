{
	"name": "Ansible Lightweight",
	"image": "mcr.microsoft.com/devcontainers/python:3.11",

	"features": {},

	"onCreateCommand": "pip install --upgrade pip",

	"postCreateCommand": "pip install ansible",

	"remoteUser": "vscode",

