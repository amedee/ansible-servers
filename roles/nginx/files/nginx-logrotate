/var/log/nginx/*.log {
    monthly
    rotate 24
    compress
    delaycompress
    missingok
    notifempty
    sharedscripts

    prerotate
      if [ -d /etc/logrotate.d/httpd-prerotate ]; then
              run-parts /etc/logrotate.d/httpd-prerotate;
      fi
    endscript

    postrotate:
      invoke-rc.d nginx rotate >/dev/null 2>&1
    endscript
}
